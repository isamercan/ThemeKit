{
  "name": "@isamercan/themekit-mcp",
  "version": "2.6.0",
  "description": "MCP server for the ThemeKit SwiftUI design system — components, modifiers, tokens and theme presets on demand.",
  "type": "module",
  "bin": {
    "themekit-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data/themekit.json",
    "figma-mapping.json",
    "migrate-rules.json",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "build:data": "tsc && node dist/datagen/buildData.js",
    "test": "tsc && node --test test/*.test.mjs"
  },
  "keywords": [
    "mcp",
    "themekit",
    "swiftui",
    "design-system"
  ],
  "author": "isamercan",
  "license": "MIT",
  "homepage": "https://github.com/isamercan/ThemeKit",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pngjs": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.5.0"
  }
}
